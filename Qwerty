5.2 Создать таблицы с полнотекстовыми индексами

5.2.1 Таблица games

```sql
-- создание таблицы
CREATE TABLE games (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255) NOT NULL,
    description TEXT
);

-- вставка данных (пример с повторяющимися словами)
INSERT INTO games (name, description) VALUES
('Игра 1', 'Стратегическая игра про космос и космос. Космос ждёт.'),
('Игра 2', 'Космос — это круто. Космос манит. Космос бесконечен.'),
('Игра 3', 'Приключение в космосе. Космос и звёзды.'),
('Игра 4', 'Гонки на машинах. Быстро и шумно.'),
('Игра 5', 'Ролевая игра с магией. Магия спасёт мир.');

-- полнотекстовые индексы
ALTER TABLE games ADD FULLTEXT idx_description (description);
ALTER TABLE games ADD FULLTEXT idx_name_description (name, description);
```

5.2.2 Таблица video_games

```sql
CREATE TABLE video_games (
    id INT PRIMARY KEY AUTO_INCREMENT,
    title VARCHAR(255),
    genres VARCHAR(255)
);

INSERT INTO video_games (title, genres) VALUES
('Game A', 'RPG, Action, Adventure'),
('Game B', 'Strategy, Simulation'),
('Game C', 'RPG, Indie, Action');

ALTER TABLE video_games ADD FULLTEXT idx_genres (genres);
```

