-- 5.1
SELECT DATABASE(), USER(), CURDATE(), CURTIME(), NOW();

-- 5.2
SELECT order_id, order_date, DAY(order_date) AS day, MONTHNAME(order_date) AS month_name
FROM market.orders WHERE YEAR(order_date) = YEAR(CURDATE());

-- 5.3
SELECT REPLACE(title, '  ', ' ') AS cleaned_title, ROUND(price / 10) * 10 AS price_rounded
FROM market.books;

-- 5.4
SELECT CONCAT(last_name, ' ', LEFT(first_name, 1), '.') AS author_short,
       CONCAT(title, ' — ', price, ' руб.') AS book_with_currency
FROM market.authors a INNER JOIN market.books b ON a.author_id = b.Authors_author_id;

-- 5.5
SELECT a.last_name, a.first_name, GROUP_CONCAT(DISTINCT b.title ORDER BY b.title SEPARATOR ', ') AS books_list
FROM market.authors a LEFT JOIN market.books b ON a.author_id = b.Authors_author_id
GROUP BY a.author_id;

-- 5.6
SELECT login, IFNULL(phone, '-') AS phone_display, NULLIF(address, '-') AS address_null_if_dash
FROM market.costumers;

-- 5.7
SELECT ROW_NUMBER() OVER (ORDER BY title) AS row_num, book_id, title, genre, price
FROM market.books;

-- 5.8
SELECT genre, title, price, price_rank
FROM (SELECT genre, title, price, DENSE_RANK() OVER (PARTITION BY genre ORDER BY price DESC) AS price_rank
      FROM market.books) AS ranked
WHERE price_rank <= 3;
