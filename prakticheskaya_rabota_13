CREATE FUNCTION GetAuthorsCountByCountry(country_param VARCHAR(45))
RETURNS INT
DETERMINISTIC
BEGIN
    DECLARE author_count INT;
    
    SELECT COUNT(*)
    INTO author_count
    FROM authors
    WHERE country = country_param;
    
    RETURN author_count;
END $$

