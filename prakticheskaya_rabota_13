DELIMITER $$

CREATE FUNCTION GetProfitByYear(year_param INT)
RETURNS DECIMAL(10,2)
DETERMINISTIC
BEGIN
    DECLARE total_profit DECIMAL(10,2);
    
    SELECT SUM(b.price * c.count)
    INTO total_profit
    FROM orders o
    JOIN constrein c ON o.order_id = c.Orders_order_id
    JOIN books b ON c.Books_book_id = b.book_id
    WHERE YEAR(o.order_date) = year_param;
    
    RETURN IFNULL(total_profit, 0);
END $$

DELIMITER ;

SELECT GetProfitByYear(2025) AS profit;
