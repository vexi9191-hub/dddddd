-- Создаём таблицу для хранения удалённых заказчиков
CREATE TABLE market.deleted_costumers (
    deleted_id INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
    costumer_id INT,
    login VARCHAR(45),
    last_name VARCHAR(45),
    first_name VARCHAR(45),
    address VARCHAR(255),
    phone VARCHAR(20),
    deleted_date DATETIME
);

-- Создаём AFTER DELETE триггер для таблицы costumers
DELIMITER $$
CREATE TRIGGER after_costumers_delete
AFTER DELETE ON market.costumers
FOR EACH ROW
BEGIN
    INSERT INTO market.deleted_costumers (costumer_id, login, last_name, first_name, address, phone, deleted_date)
    VALUES (OLD.costumer_id, OLD.login, OLD.last_name, OLD.first_name, OLD.address, OLD.phone, NOW());
END$$
DELIMITER ;

