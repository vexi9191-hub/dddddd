-- Сначала удаляем старый триггер, если есть
DROP TRIGGER IF EXISTS market.after_orders_delete;

-- Создаём изменённый триггер
DELIMITER $$
CREATE TRIGGER after_orders_delete
AFTER DELETE ON market.orders
FOR EACH ROW
BEGIN
    -- Логируем удаление
    INSERT INTO market.logs (table_name, operation, operation_datetime, current_user)
    VALUES ('orders', 'DELETE', NOW(), CURRENT_USER());
    
    -- Удаляем заказчиков, у которых нет заказов
    DELETE FROM market.costumers
    WHERE costumer_id NOT IN (
        SELECT DISTINCT Costumers_costumer_id 
        FROM market.orders 
        WHERE Costumers_costumer_id IS NOT NULL
    );
END$$
DELIMITER ;

