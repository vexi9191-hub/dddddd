-- Удаляем старый триггер, если есть
DROP TRIGGER IF EXISTS market.after_constrein_insert;


-- Создаём изменённый триггер
DELIMITER $$
CREATE TRIGGER after_constrein_insert
AFTER INSERT ON market.constrein
FOR EACH ROW
BEGIN
    DECLARE order_total DECIMAL(10,2);
    
    -- Вычисляем общую стоимость заказа
    SELECT SUM(b.price * c.count) INTO order_total
    FROM market.constrein c
    JOIN market.books b ON c.Books_book_id = b.book_id
    WHERE c.Orders_order_id = NEW.Orders_order_id;
    
    -- Записываем в глобальную переменную
    SET @orderCost = order_total;
END$$
DELIMITER ;

