-- Создаём таблицу Logs
CREATE TABLE market.logs (
    log_id INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
    table_name VARCHAR(50),
    operation VARCHAR(20),
    operation_datetime DATETIME,
    current_user VARCHAR(100)
);

-- Триггеры для таблицы books
DELIMITER $$
CREATE TRIGGER after_books_insert
AFTER INSERT ON market.books
FOR EACH ROW
BEGIN
    INSERT INTO market.logs (table_name, operation, operation_datetime, current_user)
    VALUES ('books', 'INSERT', NOW(), CURRENT_USER());
END$$

CREATE TRIGGER after_books_update
AFTER UPDATE ON market.books
FOR EACH ROW
BEGIN
    INSERT INTO market.logs (table_name, operation, operation_datetime, current_user)
    VALUES ('books', 'UPDATE', NOW(), CURRENT_USER());
END$$

CREATE TRIGGER after_books_delete
AFTER DELETE ON market.books
FOR EACH ROW
BEGIN
    INSERT INTO market.logs (table_name, operation, operation_datetime, current_user)
    VALUES ('books', 'DELETE', NOW(), CURRENT_USER());
END$$
DELIMITER ;

